# Shared package post-install hook (DEB/RPM via CPack; reference spec %include).
# Source installs invoke this after `sudo make install` (see install-post-linux.sh).

if command -v systemctl >/dev/null 2>&1; then
  systemctl stop pcsc-fido.service 2>/dev/null || true
fi

ensure_ran=0
for ensure_user in /usr/lib/pcsc-fido/ensure-pcsc-fido-user.sh /lib/pcsc-fido/ensure-pcsc-fido-user.sh; do
  if [ -x "$ensure_user" ]; then
    "$ensure_user" || exit 1
    ensure_ran=1
    break
  fi
done
if [ "$ensure_ran" -ne 1 ]; then
  printf 'error: ensure-pcsc-fido-user.sh missing or not executable\n' >&2
  exit 1
fi

if command -v modprobe >/dev/null 2>&1; then
  modprobe -q uhid || true
fi

if command -v udevadm >/dev/null 2>&1; then
  udevadm control --reload-rules || true
  udevadm trigger --name-match=uhid --action=add || true
  udevadm trigger --subsystem-match=misc --action=add || true
  udevadm trigger --subsystem-match=hidraw --action=add || true
fi

if command -v systemctl >/dev/null 2>&1; then
  systemctl daemon-reload || true
fi

exit 0
