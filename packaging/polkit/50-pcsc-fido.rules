// Headless PC/SC client for the bridge daemon (pcsc-lite README.polkit).
// polkit otherwise grants PC/SC only to active console sessions.
//
// Match the dedicated user so future pcscd/polkit tightening does not require
// pcsc-fido.service drop-ins -- update this file if upstream adds new action IDs.
polkit.addRule(function(action, subject) {
    if (action.id != "org.debian.pcsc-lite.access_pcsc" &&
        action.id != "org.debian.pcsc-lite.access_card") {
        return;
    }
    if (subject.user == "pcsc-fido") {
        return polkit.Result.YES;
    }
});
